# ========================================
# GlobalWar.live — Environment Variables
# ========================================
# Copy this file to .env and fill in your API keys
# Server-side keys (Vercel env vars) don't need VITE_ prefix

# ---- GNews (News page) ----
# Free: 100 req/day per key | https://gnews.io/register
# Rotation: add _2, _3, etc. for more capacity
GNEWS_KEY=
GNEWS_KEY_2=
GNEWS_KEY_3=
# ... add more as needed (no limit)

# ---- Alpha Vantage (Gold, Oil, Commodities) ----
# Free: 25 req/day per key | https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=
ALPHA_VANTAGE_KEY_2=
# ... add more as needed

# ---- Finnhub (Stock Indices) ----
# Free: 60 req/min | https://finnhub.io/register
FINNHUB_KEY=
FINNHUB_KEY_2=
# ... add more as needed

# ---- ACLED (Conflict Map) ----
# Free with registration | https://developer.acleddata.com/
ACLED_KEY=
ACLED_EMAIL=

# ---- Crypto (CoinGecko) ----
# NO KEY NEEDED — public API, unlimited

# ---- Forex (Frankfurter) ----
# NO KEY NEEDED — public API, unlimited
